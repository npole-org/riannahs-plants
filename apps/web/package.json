{
  "name": "@riannahs-plants/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:unit": "vitest run src/domain src/services.unit.test.js --coverage",
    "test:integration": "vitest run src/app --coverage.enabled=false",
    "test": "npm run test:unit && npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:dev": "bash ./scripts/e2e-dev-smoke.sh",
    "test:e2e:dev:debug": "PLAYWRIGHT_DEBUG=1 bash ./scripts/e2e-dev-smoke.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "vite": "^5.4.10",
    "vitest": "^3.0.7",
    "eslint-plugin-react": "^7.37.5",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
